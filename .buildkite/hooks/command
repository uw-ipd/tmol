#!/bin/bash
set -eo pipefail

# Wrap every pipeline command inside the Apptainer container with GPU access.
# The agent runs bare metal; this hook runs the actual command inside the SIF.
#
# --nv            : NVIDIA GPU support
# --writable-tmpfs: allow pip installs into a tmpfs overlay (per-step)
# --pwd           : run from the checkout directory inside the container

SIF="${APPTAINER_SIF:-/net/scratch/kdidi/buildkite-pytorch.sif}"

echo "~~~ Running inside Apptainer: $(basename $SIF)"

apptainer exec --nv --writable-tmpfs --pwd "$PWD" "$SIF" bash -c '
  set -eo pipefail

  # Install uv if not present
  command -v uv >/dev/null 2>&1 || pip install --break-system-packages --quiet uv
  export PATH=$HOME/.local/bin:$PATH

  # Use container packages as constraints so uv resolves to matching versions
  # and does not replace large packages (pyarrow, scipy, etc.) in the tmpfs overlay.
  pip freeze > /tmp/container_pins.txt 2>/dev/null
  uv pip compile pyproject.toml --all-extras \
    --constraint /tmp/container_pins.txt \
    --output-file /tmp/requirements.txt --quiet 2>/dev/null
  grep -vE "^(torch(|vision|audio)|numpy|nvidia-.*|triton|tensorrt|pynvml)==" \
    /tmp/requirements.txt > /tmp/to_install.txt
  uv pip install --system --break-system-packages --quiet -r /tmp/to_install.txt 2>/dev/null

  # Register tmol as editable (no build isolation, no deps)
  pip install --no-build-isolation --no-deps --break-system-packages --quiet -e . 2>/dev/null

  # Run the actual Buildkite command
  '"$BUILDKITE_COMMAND"'
'
